generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── AUTH / TEAM ─────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
  ANALYST
  CS      // Customer Success — sees all clients, read-only
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(ANALYST)
  avatarUrl    String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  managedClients       ClientAssignment[]
  tasks                Task[]
  operations           Operation[]
  aiConversations      AIConversation[]
  alerts               Alert[]              @relation("TriggeredAlerts")
  chatMessages         ClientChatMessage[]
  weeklyChecklists     WeeklyChecklist[]
  interactions         ClientInteraction[]
  knowledgeDocuments   KnowledgeDocument[]
  agencyActivities     AgencyActivity[]
}

// ─── CLIENTS ─────────────────────────────────────────────────────────────────

enum ClientStatus {
  ACTIVE
  PAUSED
  CHURNED
}

enum PipelineStage {
  LEAD
  PROPOSTA
  NEGOCIACAO
  ATIVO
  CHURNED
}

enum InteractionType {
  LIGACAO
  REUNIAO
  EMAIL
  WHATSAPP
  NOTA
  PROPOSTA_ENVIADA
  CONTRATO_ASSINADO
}

model Client {
  id             String        @id @default(cuid())
  name           String
  slug           String        @unique
  logoUrl        String?
  industry       String?
  website        String?
  email          String?
  phone          String?
  document       String?
  status         ClientStatus  @default(ACTIVE)
  pipelineStage  PipelineStage @default(ATIVO)
  contractValue  Decimal?
  contractStart  DateTime?
  source         String?
  tags           String[]
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  assignments       ClientAssignment[]
  platformAccounts  PlatformAccount[]
  goals             Goal[]
  metricSnapshots   MetricSnapshot[]
  campaignSnapshots CampaignSnapshot[]
  healthScores      HealthScore[]
  alerts            Alert[]
  operations        Operation[]
  tasks             Task[]
  insights          ClientInsight[]
  chat              ClientChat?
  churnRiskScores   ChurnRiskScore[]
  weeklyReports     WeeklyReport[]
  interactions      ClientInteraction[]
  asaasCustomer     AsaasCustomer?
}

model ClientInteraction {
  id          String          @id @default(cuid())
  clientId    String
  userId      String
  type        InteractionType
  description String
  createdAt   DateTime        @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([clientId, createdAt])
}

model ClientAssignment {
  id         String   @id @default(cuid())
  clientId   String
  userId     String
  isPrimary  Boolean  @default(false)
  assignedAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clientId, userId])
}

// ─── PLATFORM ACCOUNTS ───────────────────────────────────────────────────────

enum Platform {
  META_ADS
  GOOGLE_ADS
  TIKTOK_ADS
  GA4
  NUVEMSHOP
}

model PlatformAccount {
  id             String    @id @default(cuid())
  clientId       String
  platform       Platform
  externalId     String
  name           String?
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?
  active         Boolean   @default(true)
  lastSyncAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  client             Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  metricSnapshots    MetricSnapshot[]
  campaignSnapshots  CampaignSnapshot[]
  syncLogs           SyncLog[]
  nuvemshopStore     NuvemshopStore?

  @@unique([clientId, platform, externalId])
}

// ─── METRICS ─────────────────────────────────────────────────────────────────

enum MetricType {
  ROAS
  CPL
  CPA
  INVESTMENT
  CONVERSIONS
  SALES
  CTR
  CPC
  IMPRESSIONS
  REACH
  FREQUENCY
  CLICKS
  SPEND
  // ── Novas métricas e-commerce ─────────────────────────────────────────────
  FATURAMENTO      // receita total de compras
  TICKET_MEDIO     // receita / conversões
  TAXA_CONVERSAO   // conversões / sessões × 100
  CPS              // custo por sessão (spend / sessões)
  CPM              // custo por mil impressões
  CAC              // custo por aquisição de NOVO cliente (spend / novos usuários GA4)
}

model MetricSnapshot {
  id                String   @id @default(cuid())
  clientId          String
  platformAccountId String
  date              DateTime @db.Date

  spend           Decimal? @db.Decimal(12, 2)
  impressions     Int?
  clicks          Int?
  reach           Int?
  newUsers        Int?     // GA4: novos usuários únicos (base para CAC)
  frequency       Decimal? @db.Decimal(8, 4)
  ctr             Decimal? @db.Decimal(8, 4)
  cpc             Decimal? @db.Decimal(10, 4)
  conversions     Int?
  conversionValue Decimal? @db.Decimal(12, 2)
  roas            Decimal? @db.Decimal(8, 4)
  cpl             Decimal? @db.Decimal(10, 4)
  cpa             Decimal? @db.Decimal(10, 4)
  rawData         Json?

  syncedAt  DateTime @default(now())
  createdAt DateTime @default(now())

  client          Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  platformAccount PlatformAccount @relation(fields: [platformAccountId], references: [id], onDelete: Cascade)

  @@unique([platformAccountId, date])
  @@index([clientId, date])
  @@index([date])
}

// ─── GOALS ───────────────────────────────────────────────────────────────────

enum GoalPeriod {
  WEEKLY
  MONTHLY
}

model Goal {
  id          String     @id @default(cuid())
  clientId    String
  metric      MetricType
  period      GoalPeriod
  targetValue Decimal    @db.Decimal(12, 4)
  startDate   DateTime   @db.Date
  endDate     DateTime   @db.Date
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  healthScores HealthScore[]

  @@unique([clientId, metric, period, startDate])
  @@index([clientId, startDate])
}

// ─── HEALTH SCORES ───────────────────────────────────────────────────────────

enum HealthStatus {
  OTIMO
  REGULAR
  RUIM
}

model HealthScore {
  id             String       @id @default(cuid())
  clientId       String
  goalId         String
  metric         MetricType
  period         GoalPeriod
  periodStart    DateTime     @db.Date
  periodEnd      DateTime     @db.Date
  targetValue    Decimal      @db.Decimal(12, 4)
  actualValue    Decimal      @db.Decimal(12, 4)
  achievementPct Decimal      @db.Decimal(8, 4)
  status         HealthStatus
  calculatedAt   DateTime     @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  goal   Goal   @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([clientId, goalId, periodStart])
  @@index([clientId, periodStart])
  @@index([status])
}

// ─── ALERTS ──────────────────────────────────────────────────────────────────

enum AlertType {
  STATUS_DROPPED_TO_RUIM
  STATUS_DROPPED_TO_REGULAR
  STATUS_IMPROVED_TO_OTIMO
  SYNC_FAILED
  BUDGET_EXHAUSTED
  BUDGET_WARNING
  KPI_DROP_24H
  KPI_SPIKE_24H
}

model Alert {
  id          String    @id @default(cuid())
  clientId    String
  type        AlertType
  title       String
  body        String
  read        Boolean   @default(false)
  triggeredBy String?
  sentAt      DateTime?
  createdAt   DateTime  @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user   User?  @relation("TriggeredAlerts", fields: [triggeredBy], references: [id])

  @@index([clientId, read])
  @@index([createdAt])
}

// ─── TASKS ───────────────────────────────────────────────────────────────────

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TaskStatus   @default(PENDING)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  clientId    String?
  assignedTo  String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  client Client? @relation(fields: [clientId], references: [id])
  user   User    @relation(fields: [assignedTo], references: [id], onDelete: Cascade)
}

// ─── OPERATIONS (Registro de Operações) ──────────────────────────────────────

model Operation {
  id        String   @id @default(cuid())
  clientId  String
  userId    String
  subject   String
  requested String
  done      String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([clientId, createdAt])
}

// ─── AI ──────────────────────────────────────────────────────────────────────

enum AIAgentType {
  ANTI_CHURN
  PERSONA
  CAMPAIGN
}

model AIConversation {
  id        String      @id @default(cuid())
  userId    String
  clientId  String?
  agentType AIAgentType
  title     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AIMessage[]
}

model AIMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String
  content        String
  createdAt      DateTime @default(now())

  conversation AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model ClientInsight {
  id        String   @id @default(cuid())
  clientId  String
  content   String
  metric    String?
  dismissed Boolean  @default(false)
  createdAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

// ─── CLIENT CHAT ─────────────────────────────────────────────────────────────

model ClientChat {
  id        String   @id @default(cuid())
  clientId  String   @unique
  createdAt DateTime @default(now())

  client   Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  messages ClientChatMessage[]
}

model ClientChatMessage {
  id        String   @id @default(cuid())
  chatId    String
  userId    String
  content   String
  createdAt DateTime @default(now())

  chat ClientChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([chatId, createdAt])
}

// ─── WEEKLY CHECKLIST ─────────────────────────────────────────────────────────

model WeeklyChecklist {
  id        String   @id @default(cuid())
  managerId String
  weekStart DateTime @db.Date
  items     Json     // ChecklistItem[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  manager User @relation(fields: [managerId], references: [id], onDelete: Cascade)

  @@unique([managerId, weekStart])
  @@index([managerId, weekStart])
}

// ─── CHURN RISK SCORE ─────────────────────────────────────────────────────────

model ChurnRiskScore {
  id        String   @id @default(cuid())
  clientId  String
  weekStart DateTime @db.Date
  score     Int      // 0–100
  factors   Json     // breakdown of scoring factors
  createdAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, weekStart])
  @@index([clientId, weekStart])
}

// ─── WEEKLY REPORT ────────────────────────────────────────────────────────────

model WeeklyReport {
  id          String    @id @default(cuid())
  clientId    String
  weekStart   DateTime  @db.Date
  content     String    // formatted text report
  generatedAt DateTime  @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, weekStart])
  @@index([clientId, weekStart])
}

// ─── CAMPAIGN SNAPSHOTS ───────────────────────────────────────────────────────

model CampaignSnapshot {
  id                String   @id @default(cuid())
  clientId          String
  platformAccountId String
  platform          Platform
  date              DateTime @db.Date

  campaignId   String
  campaignName String
  adSetId      String  @default("")  // empty string = sem adset (evita NULL em unique constraint)
  adSetName    String?

  spend           Decimal? @db.Decimal(12, 2)
  impressions     Int?
  clicks          Int?
  reach           Int?
  ctr             Decimal? @db.Decimal(8, 4)
  cpc             Decimal? @db.Decimal(10, 4)
  conversions     Int?
  conversionValue Decimal? @db.Decimal(12, 2)
  roas            Decimal? @db.Decimal(8, 4)
  cpl             Decimal? @db.Decimal(10, 4)

  syncedAt DateTime @default(now())

  client          Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  platformAccount PlatformAccount @relation(fields: [platformAccountId], references: [id], onDelete: Cascade)

  @@unique([platformAccountId, date, campaignId, adSetId])
  @@index([clientId, date])
  @@index([platformAccountId, date])
}

// ─── SYNC LOG ────────────────────────────────────────────────────────────────

enum SyncStatus {
  RUNNING
  SUCCESS
  FAILED
}

model SyncLog {
  id                String     @id @default(cuid())
  platformAccountId String
  platform          Platform
  startedAt         DateTime   @default(now())
  completedAt       DateTime?
  status            SyncStatus @default(RUNNING)
  recordsUpserted   Int        @default(0)
  errorMessage      String?

  platformAccount PlatformAccount @relation(fields: [platformAccountId], references: [id], onDelete: Cascade)
}

// ─── NUVEMSHOP ──────────────────────────────────────────────────────────────

model NuvemshopStore {
  id              String   @id @default(cuid())
  platformAccountId String @unique
  storeId         String   @unique  // Nuvemshop store ID
  storeName       String?
  storeUrl        String?
  accessToken     String             // OAuth access token (não expira na Nuvemshop)
  scopes          String?            // scopes autorizados
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  platformAccount PlatformAccount @relation(fields: [platformAccountId], references: [id], onDelete: Cascade)
  orders          NuvemshopOrder[]
}

enum NuvemshopOrderStatus {
  OPEN
  CLOSED
  CANCELLED
}

enum NuvemshopPaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  VOIDED
  REFUNDED
  ABANDONED
}

enum NuvemshopFulfillmentStatus {
  UNPACKED
  FULFILLED
  UNFULFILLED
  PARTIALLY_FULFILLED
}

model NuvemshopOrder {
  id                  String                    @id @default(cuid())
  storeId             String
  nuvemshopOrderId    String                    // ID do pedido na Nuvemshop
  orderNumber         Int?                      // Número do pedido visível ao lojista
  status              NuvemshopOrderStatus      @default(OPEN)
  paymentStatus       NuvemshopPaymentStatus    @default(PENDING)
  fulfillmentStatus   NuvemshopFulfillmentStatus @default(UNPACKED)

  currency            String   @default("BRL")
  subtotal            Decimal  @db.Decimal(12, 2) // valor dos produtos
  discount            Decimal  @default(0) @db.Decimal(12, 2)
  shippingCost        Decimal  @default(0) @db.Decimal(12, 2)
  total               Decimal  @db.Decimal(12, 2) // valor final cobrado

  productsCount       Int      @default(0)        // quantidade de itens
  couponCodes         String[] // cupons aplicados

  customerEmail       String?
  customerName        String?

  // UTM params capturados para cruzamento com GA4
  utmSource           String?
  utmMedium           String?
  utmCampaign         String?
  utmContent          String?
  utmTerm             String?
  landingUrl          String?  // URL de entrada do visitante
  referralUrl         String?  // URL de referência (de onde veio)
  storefront          String?  // canal de venda (web, mobile, etc.)

  // Rastreamento GA4
  ga4TransactionId    String?  // transaction_id do GA4 para cruzamento
  ga4Matched          Boolean  @default(false) // se foi cruzado com sucesso

  closedAt            DateTime?
  cancelledAt         DateTime?
  paidAt              DateTime?
  orderCreatedAt      DateTime  // data original do pedido na Nuvemshop

  rawData             Json?     // resposta completa da API
  syncedAt            DateTime  @default(now())
  createdAt           DateTime  @default(now())

  store NuvemshopStore @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, nuvemshopOrderId])
  @@index([storeId, orderCreatedAt])
  @@index([storeId, paymentStatus])
  @@index([ga4TransactionId])
  @@index([orderCreatedAt])
}

// ─── KNOWLEDGE BASE ───────────────────────────────────────────────────────────

model KnowledgeDocument {
  id           String   @id @default(cuid())
  filename     String
  title        String
  uploadedById String
  chunkCount   Int      @default(0)
  tags         String[] @default(["ALL"]) // ALL | ECOMMERCE | LOCAL | CS
  createdAt    DateTime @default(now())

  uploader User             @relation(fields: [uploadedById], references: [id])
  chunks   KnowledgeChunk[]
}

model KnowledgeChunk {
  id         String @id @default(cuid())
  documentId String
  content    String
  position   Int

  document KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

// ─── FINANCEIRO / ASAAS ───────────────────────────────────────────────────────

enum AsaasPaymentStatus {
  PENDING
  RECEIVED
  CONFIRMED
  OVERDUE
  REFUNDED
  REFUND_REQUESTED
  CHARGEBACK_REQUESTED
  AWAITING_RISK_ANALYSIS
}

enum AsaasBillingType {
  BOLETO
  PIX
  CREDIT_CARD
  DEBIT_CARD
  TRANSFER
  DEPOSIT
  UNDEFINED
}

model AsaasCustomer {
  id        String   @id @default(cuid())
  asaasId   String   @unique
  name      String
  email     String?
  cpfCnpj   String?
  phone     String?
  syncedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientId String? @unique
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  payments      AsaasPayment[]
  subscriptions AsaasSubscription[]

  @@index([cpfCnpj])
}

model AsaasPayment {
  id          String             @id @default(cuid())
  asaasId     String             @unique
  status      AsaasPaymentStatus
  billingType AsaasBillingType   @default(UNDEFINED)
  value       Decimal            @db.Decimal(12, 2)
  netValue    Decimal?           @db.Decimal(12, 2)
  dueDate     DateTime           @db.Date
  paymentDate DateTime?          @db.Date
  description String?
  invoiceUrl  String?
  syncedAt    DateTime           @default(now())
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  customerId String?
  customer   AsaasCustomer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([dueDate])
  @@index([paymentDate])
  @@index([customerId])
}

model AsaasSubscription {
  id          String   @id @default(cuid())
  asaasId     String   @unique
  status      String   // ACTIVE, INACTIVE, EXPIRED
  cycle       String   // MONTHLY, WEEKLY, QUARTERLY, YEARLY
  value       Decimal  @db.Decimal(12, 2)
  nextDueDate DateTime? @db.Date
  description String?
  syncedAt    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customerId String?
  customer   AsaasCustomer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([customerId])
}

model AsaasTransfer {
  id           String    @id @default(cuid())
  asaasId      String    @unique
  status       String    // PENDING, BANK_PROCESSING, DONE, CANCELLED, FAILED
  value        Decimal   @db.Decimal(12, 2)
  netValue     Decimal?  @db.Decimal(12, 2)
  transferDate DateTime  @db.Date
  scheduleDate DateTime? @db.Date
  description  String?
  operationType String?  // TEV, TED, PIX
  syncedAt     DateTime  @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  categoryId String?
  category   FinancialCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([transferDate])
  @@index([status])
  @@index([categoryId])
}

model FinancialCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  type      String   // REVENUE | EXPENSE
  color     String   @default("#6B7280")
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transfers AsaasTransfer[]
}

// ─── CRM COMERCIAL (pipeline de vendas da agência) ────────────────────────────

enum AgencyLeadStatus {
  NOVO
  EM_CONTATO
  REUNIAO_AGENDADA
  PROPOSTA_ENVIADA
  PROPOSTA_ACEITA
  FECHADO
  PERDIDO
}

model AgencyLead {
  id          String           @id @default(cuid())
  name        String
  email       String?
  phone       String?
  company     String?
  source      String?          // "indicação", "site", "instagram"
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?
  status      AgencyLeadStatus @default(NOVO)
  value       Decimal?         @db.Decimal(12, 2)  // valor potencial do contrato
  probability Int?             // 0-100
  expectedCloseAt DateTime?    @db.Date
  closedAt             DateTime?
  lostReason           String?
  notes                String?          @db.Text
  convertedClientId    String?
  convertedAt          DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  deletedAt            DateTime?

  activities AgencyActivity[]

  @@index([status])
  @@index([createdAt])
}

enum AgencyActivityType {
  NOTA
  LIGACAO
  EMAIL
  REUNIAO
  WHATSAPP
  STATUS_CHANGE
}

model AgencyActivity {
  id         String             @id @default(cuid())
  type       AgencyActivityType
  title      String
  body       String?            @db.Text
  occurredAt DateTime           @default(now())
  createdAt  DateTime           @default(now())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  leadId String?
  lead   AgencyLead? @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

// ─── INTEGRATION SETTINGS ────────────────────────────────────────────────────

model IntegrationSetting {
  key       String   @id   // e.g. "EVOLUTION_URL", "EVOLUTION_KEY", "EVOLUTION_INSTANCE"
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}
