{
  "crons": [
    {
      "path": "/api/cron/daily",
      "schedule": "30 11 * * *"
    },
    {
      "path": "/api/cron/digest",
      "schedule": "50 11 * * *"
    }
  ],
  "functions": {
    "src/app/api/sync/**": {
      "maxDuration": 300
    },
    "src/app/api/cron/**": {
      "maxDuration": 300
    },
    "src/app/api/nuvemshop/**": {
      "maxDuration": 60
    },
    "src/app/api/admin/knowledge/**": {
      "maxDuration": 120
    }
  }
}
